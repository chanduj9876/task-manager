# ============================================================
#  Task Manager — Environment Variables
#  1. Copy this file:  cp .env.example .env
#  2. Fill in the required values marked with (REQUIRED)
#  3. Never commit the real .env file to version control
# ============================================================

# ── JWT ─────────────────────────────────────────────────────
# (REQUIRED) Minimum 32 characters. Generate with:
#   openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-secret-min-32-chars

# Token lifetime in milliseconds (default: 24 hours)
JWT_EXPIRATION_MS=86400000

# ── Database ────────────────────────────────────────────────
DB_NAME=taskmanager
DB_USER=taskuser
DB_PASSWORD=taskpassword

# ── Frontend ────────────────────────────────────────────────
# Leave empty when Nginx and the backend run in the same Docker Compose stack.
# Nginx automatically proxies /api and /ws to the backend container.
# Set to https://api.yourdomain.com only when deploying on separate servers/CDN.
VITE_API_BASE_URL=
VITE_WS_URL=

# ── Ports (optional overrides) ──────────────────────────────
# Port the frontend Nginx container listens on (default: 80)
FRONTEND_PORT=80
